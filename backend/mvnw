#!/bin/sh
set -eu
MAVEN_PROJECTBASEDIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
if [ ! -r "$JAR" ]; then
  echo "Missing $JAR" >&2
  exit 1
fi

if [ -n "${JAVA_HOME-}" ] && [ -x "$JAVA_HOME/bin/java" ]; then
  JAVACMD="$JAVA_HOME/bin/java"
else
  JAVACMD="$(command -v java 2>/dev/null || true)"
fi
if [ -z "$JAVACMD" ] || [ ! -x "$JAVACMD" ]; then
  echo "Install JDK 21+ and ensure java is on PATH (or set JAVA_HOME)." >&2
  exit 1
fi

exec "$JAVACMD" ${MAVEN_OPTS-} \
  -classpath "$JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
