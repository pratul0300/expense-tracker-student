# API base hostname (production). Omit or leave empty when using Vite dev server:
# `/api` is proxied to http://localhost:8080 locally (see vite.config.js).
# On Vercel, set this to your Render HTTPS root, e.g. https://student-expense-api.onrender.com
# (do not append /api — the frontend appends /api to match Spring routes).
VITE_API_URL=
